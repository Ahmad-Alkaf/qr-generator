generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User (synced from Clerk via webhook) ────────────
model User {
  id      String @id @default(cuid())
  clerkId String @unique
  email   String @unique
  name    String?
  image   String?
  plan    Plan   @default(FREE)

  qrCodes QRCode[]
  scans   Scan[]

  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
  @@index([email])
  @@index([stripeCustomerId])
}

// ─── Core ────────────────────────────────────────────
enum Plan {
  FREE
  PRO
  BUSINESS
}

enum QRType {
  URL
  WIFI
  VCARD
  EMAIL
  SMS
  WHATSAPP
  PDF
  PLAIN_TEXT
}

model QRCode {
  id      String  @id @default(cuid())
  userId  String?
  type    QRType
  name    String?
  content String  @db.Text

  // Customization
  foregroundColor String @default("#000000")
  backgroundColor String @default("#FFFFFF")
  logoUrl         String?
  style           String @default("squares")
  errorCorrection String @default("M")
  size            Int    @default(300)

  // Direct QR: encodes content directly (no redirect, no analytics, faster scan)
  // Tracked QR: encodes a short redirect URL (enables analytics + editable destination)
  isDirect       Boolean @default(true)

  // Tracked QR fields (isDirect=false)
  shortCode      String? @unique
  destinationUrl String? @db.Text

  // Dynamic: tracked QR where destination can be changed after creation (Pro+)
  isDynamic      Boolean @default(false)

  // File outputs
  pngUrl String?
  svgUrl String?

  scans Scan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([shortCode])
  @@index([createdAt])
}

model Scan {
  id       String  @id @default(cuid())
  qrCodeId String
  userId   String?

  ip      String?
  country String?
  city    String?
  device  String?
  os      String?
  browser String?
  referer String?

  scannedAt DateTime @default(now())

  qrCode QRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([qrCodeId])
  @@index([scannedAt])
  @@index([qrCodeId, scannedAt])
}
