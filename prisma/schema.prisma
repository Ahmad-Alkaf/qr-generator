generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)

  accounts Account[]
  sessions Session[]
  qrCodes  QRCode[]
  scans    Scan[]

  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([stripeCustomerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core ────────────────────────────────────────────
enum Plan {
  FREE
  PRO
  BUSINESS
}

enum QRType {
  URL
  WIFI
  VCARD
  EMAIL
  SMS
  WHATSAPP
  PDF
  PLAIN_TEXT
}

model QRCode {
  id      String  @id @default(cuid())
  userId  String?
  type    QRType
  name    String?
  content String  @db.Text

  // Customization
  foregroundColor String @default("#000000")
  backgroundColor String @default("#FFFFFF")
  logoUrl         String?
  style           String @default("squares")
  errorCorrection String @default("M")
  size            Int    @default(300)

  // Direct QR: encodes content directly (no redirect, no analytics, faster scan)
  // Tracked QR: encodes a short redirect URL (enables analytics + editable destination)
  isDirect       Boolean @default(true)

  // Tracked QR fields (isDirect=false)
  shortCode      String? @unique              // e.g., "abc123" → qrforge.app/r/abc123
  destinationUrl String? @db.Text             // The actual target URL (editable for tracked QR)

  // Dynamic: tracked QR where destination can be changed after creation (Pro+)
  isDynamic      Boolean @default(false)

  // File outputs
  pngUrl String?
  svgUrl String?

  scans Scan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([shortCode])
  @@index([createdAt])
}

model Scan {
  id       String  @id @default(cuid())
  qrCodeId String
  userId   String?

  ip      String?
  country String?
  city    String?
  device  String?
  os      String?
  browser String?
  referer String?

  scannedAt DateTime @default(now())

  qrCode QRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([qrCodeId])
  @@index([scannedAt])
  @@index([qrCodeId, scannedAt])
}
